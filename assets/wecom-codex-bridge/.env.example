# Required
WECOM_CORP_ID=ww_xxx
WECOM_AGENT_ID=1000002
WECOM_CORP_SECRET=xxx
WECOM_TOKEN=your_callback_token
WECOM_ENCODING_AES_KEY=your_43_char_encoding_aes_key

# HTTP callback server
WECOM_BIND_HOST=0.0.0.0
WECOM_BIND_PORT=8080
WECOM_CALLBACK_PATH=/wecom/callback

# Codex
CODEX_BIN=codex
CODEX_DEFAULT_CWD=/Users/linxiaoyi
CODEX_HOME=/Users/linxiaoyi/.codex
CODEX_SANDBOX=workspace-write
CODEX_AUTO_RESUME=0
SESSION_STATE_FILE=.wecom_session_map.json

# Security
ALLOWED_USER_IDS=
COMMAND_TOKEN=
RATE_LIMIT_PER_MINUTE=20
MAX_USER_TEXT_CHARS=8000
STATUS_RECEIVED_TEXT=⏳ 已收到，开始处理
LOG_LEVEL=INFO
