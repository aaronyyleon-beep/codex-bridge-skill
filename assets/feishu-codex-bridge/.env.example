# Required
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional
CODEX_BIN=codex
CODEX_DEFAULT_CWD=/Users/linxiaoyi
CODEX_HOME=/Users/linxiaoyi/.codex
SESSION_STATE_FILE=.feishu_session_map.json
STREAM_CHUNK_CHARS=800
STREAM_FLUSH_SEC=2.0
STREAM_SEND_INTERVAL_SEC=0.12
STREAM_PSEUDO_CHUNK_CHARS=32
STREAM_EDIT_IN_PLACE=1
STREAM_USE_MARKDOWN=1
STREAM_UPDATE_INTERVAL_SEC=0.25
STREAM_MAX_UPDATES_PER_MESSAGE=18
STREAM_MESSAGE_MAX_CHARS=4000
MERGE_WINDOW_SEC=0.3
STATUS_RECEIVED_TEXT=⏳ 已收到，正在思考...
STREAM_MARKDOWN_TITLE=

# Security
REQUIRE_P2P=1
ALLOWED_OPEN_IDS=
ALLOWED_CHAT_IDS=
COMMAND_TOKEN=
ENABLE_RAW_CMD=0
RATE_LIMIT_PER_MINUTE=20
MAX_USER_TEXT_CHARS=8000
SEND_UNAUTHORIZED_NOTICE=0
UNAUTHORIZED_NOTICE_TEXT=⛔️ 未授权访问
RATE_LIMIT_NOTICE_TEXT=⏱ 请求过于频繁，请稍后再试
LOG_LEVEL=INFO
